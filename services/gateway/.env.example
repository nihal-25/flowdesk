# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Upstream Service URLs ────────────────────────────────────────────────────
# Internal service addresses (use Docker service names in production)
AUTH_SERVICE_URL=http://localhost:3001
TICKETS_SERVICE_URL=http://localhost:3002
CHAT_SERVICE_URL=http://localhost:3003
NOTIFICATIONS_SERVICE_URL=http://localhost:3004
ANALYTICS_SERVICE_URL=http://localhost:3005

# ─── PostgreSQL (for API key validation) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USER=flowdesk
DB_PASSWORD=flowdesk_secret
DB_SSL=false   # Set to true for Railway/production

# ─── Redis (for rate limiting and token blacklist) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret   # Match docker-compose REDIS_PASSWORD
REDIS_TLS=false               # Set to true for Railway managed Redis

# ─── JWT (must match auth service secret for token verification) ──────────────
JWT_ACCESS_SECRET=replace_me_with_64_char_hex_string_access

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per minute per tenant (sliding window via Redis)
RATE_LIMIT_TENANT_RPM=1000
# Requests per minute per IP address
RATE_LIMIT_IP_RPM=100

# ─── Kafka / Redpanda Cloud ───────────────────────────────────────────────────
KAFKA_BROKERS=your-cluster.redpanda.cloud:9092
KAFKA_SASL_USERNAME=your-sasl-username
KAFKA_SASL_PASSWORD=your-sasl-password

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
