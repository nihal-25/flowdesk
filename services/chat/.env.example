# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USER=flowdesk
DB_PASSWORD=flowdesk_secret
DB_SSL=false   # Set to true for Railway/production

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis is critical for chat: pub/sub for cross-instance message fanout,
# and presence tracking (online agents sorted set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret   # Match docker-compose REDIS_PASSWORD
REDIS_TLS=false               # Set to true for Railway managed Redis

# ─── JWT (for Socket.IO handshake authentication) ────────────────────────────
# Must match the access secret used by the auth service
JWT_ACCESS_SECRET=replace_me_with_64_char_hex_string_access

# ─── Kafka / Redpanda Cloud ───────────────────────────────────────────────────
# Chat publishes: chat.message.sent
# Chat consumes: ticket.created, ticket.updated (to sync real-time state)
KAFKA_BROKERS=your-cluster.redpanda.cloud:9092
KAFKA_SASL_USERNAME=your-sasl-username
KAFKA_SASL_PASSWORD=your-sasl-password

# ─── Socket.IO Configuration ─────────────────────────────────────────────────
# Allowed origins for WebSocket connections (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Presence heartbeat interval in milliseconds (clients send ping every N ms)
PRESENCE_HEARTBEAT_INTERVAL_MS=30000
# Time in seconds before a user is considered offline (should be > heartbeat)
PRESENCE_TTL_SECONDS=60
