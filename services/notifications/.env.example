# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USER=flowdesk
DB_PASSWORD=flowdesk_secret
DB_SSL=false   # Set to true for Railway/production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret   # Match docker-compose REDIS_PASSWORD
REDIS_TLS=false               # Set to true for Railway managed Redis

# ─── Kafka / Redpanda Cloud ───────────────────────────────────────────────────
# Notifications consumes: ticket.created, ticket.updated, ticket.assigned,
# ticket.closed, ticket.message.added
KAFKA_BROKERS=your-cluster.redpanda.cloud:9092
KAFKA_SASL_USERNAME=your-sasl-username
KAFKA_SASL_PASSWORD=your-sasl-password

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Generate App Password at: https://myaccount.google.com/apppasswords
# Do NOT use your Gmail login password here — use an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false             # true for port 465, false for port 587 (STARTTLS)
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=FlowDesk <noreply@yourdomain.com>

# ─── Webhook Delivery ────────────────────────────────────────────────────────
# HMAC secret for signing outbound webhook payloads
# Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=replace_me_with_64_char_hex_string

# Number of delivery attempts before marking an endpoint as failed
WEBHOOK_MAX_ATTEMPTS=5
# Base delay in milliseconds for exponential backoff (doubles each retry)
WEBHOOK_BACKOFF_BASE_MS=1000

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
