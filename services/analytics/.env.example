# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USER=flowdesk
DB_PASSWORD=flowdesk_secret
DB_SSL=false   # Set to true for Railway/production

# ─── Redis (for caching aggregated stats) ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret   # Match docker-compose REDIS_PASSWORD
REDIS_TLS=false               # Set to true for Railway managed Redis

# ─── Kafka / Redpanda Cloud ───────────────────────────────────────────────────
# Analytics consumes all ticket and chat events to build aggregates:
# ticket.created, ticket.updated, ticket.assigned, ticket.closed,
# ticket.message.added, chat.message.sent
KAFKA_BROKERS=your-cluster.redpanda.cloud:9092
KAFKA_SASL_USERNAME=your-sasl-username
KAFKA_SASL_PASSWORD=your-sasl-password

# ─── Cache TTLs ───────────────────────────────────────────────────────────────
# How long to cache analytics responses in Redis (seconds)
# Overview stats are expensive — cache for 5 minutes
ANALYTICS_CACHE_TTL_SECONDS=300
# Per-agent stats cache TTL
AGENT_STATS_CACHE_TTL_SECONDS=120

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
