# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USER=flowdesk
DB_PASSWORD=flowdesk_secret
DB_SSL=false   # Set to true for Railway/production

# ─── Redis (for caching and pub/sub) ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret   # Match docker-compose REDIS_PASSWORD
REDIS_TLS=false               # Set to true for Railway managed Redis

# ─── Kafka / Redpanda Cloud ───────────────────────────────────────────────────
# Tickets publishes events: ticket.created, ticket.updated, ticket.assigned,
# ticket.closed, ticket.message.added
KAFKA_BROKERS=your-cluster.redpanda.cloud:9092
KAFKA_SASL_USERNAME=your-sasl-username
KAFKA_SASL_PASSWORD=your-sasl-password

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Pagination defaults ──────────────────────────────────────────────────────
# Maximum number of tickets returned per page
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
